[Unit]
Description=Personal AI Assistant
Documentation=https://github.com/your-org/personal-ai-assistant
After=network.target
Wants=network-online.target

[Service]
Type=simple
# install.sh replaces these placeholders
User=%INSTALL_USER%
Group=%INSTALL_USER%
WorkingDirectory=%PROJECT_DIR%
ExecStart=%PROJECT_DIR%/.venv/bin/python -m src.main
Restart=always
RestartSec=10
TimeoutStopSec=30

# -- Security Hardening --

NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%PROJECT_DIR%/data /opt/ai-assistant/logs /opt/ai-assistant/models /opt/ai-assistant/src /opt/ai-assistant/skills /opt/ai-assistant/mcps /opt/ai-assistant/.backups /tmp
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes

# Network: allow IPv4, IPv6, and Unix sockets only
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX

# Misc restrictions
RestrictRealtime=yes
RestrictSUIDSGID=yes
RestrictNamespaces=yes
LockPersonality=yes
SystemCallArchitectures=native

# -- Resource Limits --

MemoryMax=2G
MemoryHigh=1536M
TasksMax=256
LimitNOFILE=4096

# -- Environment --

EnvironmentFile=%PROJECT_DIR%/.env

# -- Logging --

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ai-assistant

[Install]
WantedBy=multi-user.target
