# ============================================================================
# Personal AI Assistant — Variables de Entorno
# ============================================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================================

# --- Telegram ---
# Token del bot obtenido de @BotFather en Telegram
TELEGRAM_BOT_TOKEN=

# ID del chat autorizado para usar el bot (solo este usuario puede interactuar)
# Obtener con: enviar /start al bot @userinfobot en Telegram
AUTHORIZED_CHAT_ID=

# PIN de seguridad OBLIGATORIO para operaciones invasivas (mínimo 4 dígitos)
# Sin este PIN el sistema NO arranca. Se pide antes de: borrar archivos,
# modificar código, instalar software, y cualquier acción destructiva.
# 3 intentos fallidos = bloqueo de 24 horas (anti brute-force).
SECURITY_PIN=

# --- Claude CLI ---
# Ruta al ejecutable de Claude CLI
CLAUDE_CLI_PATH=claude

# Directorio base donde se encuentran los proyectos que el asistente puede gestionar
# Linux: /home | Mac: /Users | Windows: C:\Users (se detecta automáticamente si está vacío)
PROJECTS_BASE_DIR=

# --- Límites y Seguridad ---
# Máximo de mensajes permitidos por minuto (protección contra flood)
MAX_MESSAGES_PER_MINUTE=20

# Requiere aprobación explícita antes de ejecutar acciones destructivas (true/false)
REQUIRE_APPROVAL=true

# --- Zona Horaria ---
# Zona horaria para recordatorios y tareas programadas
# Ejemplos: America/New_York, America/Mexico_City, Europe/Madrid
TIMEZONE=America/New_York

# --- Base de Datos ---
# Clave de cifrado para la base de datos SQLite (SQLCipher)
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
DB_ENCRYPTION_KEY=

# --- Multi-modelo (Fallback) ---
# Clave API de OpenAI (dejar vacío para desactivar)
OPENAI_API_KEY=
# Modelo de OpenAI a usar como fallback
OPENAI_MODEL=gpt-4o
# URL base personalizada para OpenAI (vacío = api.openai.com)
OPENAI_BASE_URL=
# Modelo de Ollama (local) a usar como fallback
OLLAMA_MODEL=llama3.2
# URL del servidor Ollama
OLLAMA_BASE_URL=http://localhost:11434

# --- Modelos de Audio ---
# Modelo de Whisper para speech-to-text local
# Opciones: tiny, base, small, medium, large-v3
# Más grande = más preciso pero más lento y más RAM
WHISPER_MODEL=medium

# Modelo de text-to-speech local
TTS_MODEL=chatterbox

# --- Mascota de Escritorio ---
# Habilitar mascota desktop (true/false). Requiere PyQt6: pip install PyQt6
PET_ENABLED=false
# Tipo de mascota: dog, cat, robot, fox, owl
PET_TYPE=dog
# Tamaño en píxeles (96 recomendado)
PET_SIZE=96
# Monitor donde aparece (0 = primario, 1 = secundario, etc.)
PET_MONITOR=0

# --- Gmail (App Passwords, IMAP/SMTP) ---
# Clave para encriptar las credenciales de Gmail almacenadas en disco.
# Si se deja vacío, se genera automáticamente y se guarda en data/.gmail_key
# Generar manualmente con: python -c "import secrets; print(secrets.token_hex(32))"
GMAIL_ENCRYPTION_KEY=

# --- Logging ---
# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
