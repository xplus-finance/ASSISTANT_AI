# ============================================================================
# Personal AI Assistant — Variables de Entorno
# ============================================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================================

# --- Telegram ---
# Token del bot obtenido de @BotFather en Telegram
TELEGRAM_BOT_TOKEN=

# ID del chat autorizado para usar el bot (solo este usuario puede interactuar)
# Obtener con: enviar /start al bot @userinfobot en Telegram
AUTHORIZED_CHAT_ID=

# PIN de seguridad opcional para operaciones sensibles (dejar vacío para desactivar)
SECURITY_PIN=

# --- Claude CLI ---
# Ruta al ejecutable de Claude CLI
CLAUDE_CLI_PATH=claude

# Directorio base donde se encuentran los proyectos que el asistente puede gestionar
PROJECTS_BASE_DIR=/home

# --- Límites y Seguridad ---
# Máximo de mensajes permitidos por minuto (protección contra flood)
MAX_MESSAGES_PER_MINUTE=20

# Requiere aprobación explícita antes de ejecutar acciones destructivas (true/false)
REQUIRE_APPROVAL=true

# --- Zona Horaria ---
# Zona horaria para recordatorios y tareas programadas
# Ejemplos: America/New_York, America/Mexico_City, Europe/Madrid
TIMEZONE=America/New_York

# --- Base de Datos ---
# Clave de cifrado para la base de datos SQLite (SQLCipher)
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
DB_ENCRYPTION_KEY=

# --- Modelos de Audio ---
# Modelo de Whisper para speech-to-text local
# Opciones: tiny, base, small, medium, large-v3
# Más grande = más preciso pero más lento y más RAM
WHISPER_MODEL=medium

# Modelo de text-to-speech local
TTS_MODEL=chatterbox

# --- Logging ---
# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
